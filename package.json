{
  "name": "gokul-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-ports.ps1",
    "dev:web": "vite --host --port 8080 --strictPort",
    "dev:api": "python -m uvicorn backend.main:app --reload --host 127.0.0.1 --port 8000",
    "start": "node scripts/dev.mjs",
    "preview": "vite preview --host --port 8080",
    "build": "node scripts/vercel-build.mjs"
  },
  "dependencies": {
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "qrcode-terminal": "^0.12.0",
    "vite": "^6.3.5"
  }
}
